    PERSON {
        string id PK
        string name
        string email
        string phone
        string linkedin_url
        string organization_id FK
        string status
        timestamp created_at
        timestamp updated_at
    }

    ORGANIZATION {
        string id PK
        string name
        string website
        string industry
        string status
        timestamp created_at
        timestamp updated_at
    }

